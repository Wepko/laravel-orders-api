				{
					"name": "Update Order Status",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Допустимые статусы для перехода:",
									"// new → confirmed, cancelled",
									"// confirmed → processing, cancelled",
									"// processing → shipped",
									"// shipped → completed",
									"const validStatuses = ['confirmed', 'processing', 'shipped', 'completed', 'cancelled'];",
									"pm.variables.set('new_status', validStatuses[0]);"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Order status has changed', function() {",
									"    const response = pm.response.json();",
									"    const requestBody = JSON.parse(pm.request.body.raw);",
									"    pm.expect(response.status).to.equal(requestBody.status);",
									"});",
									"",
									"pm.test('Confirmed_at is set when status is confirmed', function() {",
									"    const response = pm.response.json();",
									"    if (response.status === 'confirmed') {",
									"        pm.expect(response.confirmed_at).to.not.be.null;",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
